# --- App ---
APP_NAME=upload-doc-service
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Used to build stored s3_url values (spec §15.1 decision: auth-proxy).
PUBLIC_BASE_URL=http://localhost:8000

# DATABASE_URL is NOT defined here on purpose.
# Containers: set in docker-compose.yml.
# Local uvicorn: falls back to default in app/config.py.

# --- Redis / Celery (microservice internal queue) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# RATE_LIMIT_STORAGE_URI defaults to memory:// for local dev.
# docker-compose sets it inline to redis:// (same pattern as DATABASE_URL).

# --- AWS / S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=eu-north-1
# Optional: override endpoint for local MinIO / LocalStack
# S3_ENDPOINT_URL=http://localstack:4566

# --- Uploads (spec §6.1) ---
UPLOAD_MAX_BYTES=10485760

# --- OCR (spec §10) ---
OCR_API_KEY=
OCR_DEFAULT_LANGUAGE=eng
OCR_REQUEST_TIMEOUT_SECONDS=60
OCR_MAX_RETRIES=3

# --- External base64 storage service ---
BASE64_SERVICE_URL=
BASE64_SERVICE_API_KEY=
BASE64_SERVICE_TIMEOUT_SECONDS=60
BASE64_MAX_RETRIES=3
